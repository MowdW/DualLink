{
  "name": "obsidian-dual-link",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force dist, main.js -ErrorAction SilentlyContinue\"",
    "type-check": "tsc --noEmit",
    "build:web": "vite build",
    "build:plugin": "node esbuild.config.mjs production",
    "build": "npm run clean && npm run type-check && npm run build:web && npm run build:plugin",
    "preview": "vite preview --port=3000 --host=0.0.0.0",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "obsidian": "^1.12.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
